# ============================================================
# AmanKlik AI - Frontend Environment Variables
# ============================================================
# Salin file ini menjadi .env.local dan isi dengan nilai yang sesuai.
# cp .env.example .env.local

# Google OAuth Client ID (sama dengan yang di backend)
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com

# Backend API URL
# Development: http://localhost:5000/api/v1
# Production: https://your-backend-url.run.app/api/v1
NEXT_PUBLIC_API_URL=http://localhost:5000/api/v1
